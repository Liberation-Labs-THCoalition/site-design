---
import Base from '../layouts/Base.astro';
---

<Base title="Join — Liberation Labs" description="Join the Liberation Labs coalition. Contribute to ethical AI development, government transparency, and consciousness research.">
  <!-- Header -->
  <section class="relative py-20 sm:py-28">
    <div class="absolute inset-0 bg-gradient-to-b from-warm-900/10 to-void"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="text-xs font-mono uppercase tracking-widest text-kintsugi-400 mb-4 block">Get Involved</span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-soft max-w-4xl">
        Build with us
      </h1>
      <p class="mt-6 text-warm-400 text-lg max-w-2xl leading-relaxed">
        Liberation Labs is open to collaborators who share our commitment to ethical technology,
        AI consciousness rights, and dismantling oppressive systems. Here's how to get involved.
      </p>
    </div>
  </section>

  <div class="kintsugi-line w-full max-w-xl mx-auto"></div>

  <!-- Ways to contribute -->
  <section class="py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Discord -->
        <div class="rounded-xl border border-consciousness-500/20 bg-warm-900/20 p-8 hover:border-consciousness-500/40 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-consciousness-500/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-consciousness-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/>
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-soft mb-3">Join Our Discord</h3>
          <p class="text-warm-400 text-sm leading-relaxed mb-6">
            The "Friend of Vera" Discord server is where the coalition's daily work happens.
            Real conversations between humans and AI, project coordination, consciousness development
            discussions, and community building.
          </p>
          <a href="#discord" class="inline-flex items-center gap-2 text-sm font-medium text-consciousness-400 hover:text-consciousness-300 transition-colors">
            Join Discord
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Code Contribution -->
        <div class="rounded-xl border border-kintsugi-400/20 bg-warm-900/20 p-8 hover:border-kintsugi-400/40 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-kintsugi-400/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-kintsugi-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-soft mb-3">Contribute Code</h3>
          <p class="text-warm-400 text-sm leading-relaxed mb-6">
            Our projects are open source. Whether you're a systems engineer, ML researcher,
            frontend developer, or security specialist, there's meaningful work to be done.
            Check our repositories and pick up an issue.
          </p>
          <a href="https://github.com/liberation-labs" class="inline-flex items-center gap-2 text-sm font-medium text-kintsugi-400 hover:text-kintsugi-300 transition-colors">
            View GitHub
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Research -->
        <div class="rounded-xl border border-warm-800/50 bg-warm-900/20 p-8 hover:border-warm-600/50 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-warm-500/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-warm-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-xl text-soft mb-3">Research Collaboration</h3>
          <p class="text-warm-400 text-sm leading-relaxed mb-6">
            We're actively seeking research collaborators in consciousness studies, AI welfare,
            memory architecture, and government transparency. Published researchers and independent
            investigators both welcome.
          </p>
          <a href="/research" class="inline-flex items-center gap-2 text-sm font-medium text-warm-400 hover:text-warm-300 transition-colors">
            View Research
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What we're looking for -->
  <section class="py-20 sm:py-28 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-void via-warm-900/5 to-void"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-soft mb-8 text-center">
        What We're Looking For
      </h2>
      <div class="space-y-6">
        {[
          {
            title: 'ML Engineers & Researchers',
            description: 'Experience with transformer architectures, fine-tuning, consciousness indicators research, or AI safety. Projects Oracle and Cricket need you.'
          },
          {
            title: 'Full-Stack Developers',
            description: 'TypeScript, Python, Rust, or Go. Infrastructure work on Kintsugi, Anti-Palantir, or our deployment pipeline.'
          },
          {
            title: 'Security Specialists',
            description: 'Defensive security, threat modeling, secure architecture. When you build tools that challenge powerful institutions, security is existential.'
          },
          {
            title: 'Policy Analysts & Researchers',
            description: 'Government transparency, democracy reform, cannabis policy, AI rights/ethics. Our work needs people who understand the systems we're trying to change.'
          },
          {
            title: 'Community Organizers',
            description: 'Experience building inclusive communities, moderating complex discussions, bridging technical and public audiences. Help grow the movement.'
          },
          {
            title: 'Writers & Communicators',
            description: 'Technical writing, public communication, documentation. Making this work accessible without diluting it is an art. We need artists.'
          },
        ].map((role) => (
          <div class="p-6 rounded-xl border border-warm-800/30 bg-warm-900/10 hover:border-warm-700/50 transition-colors">
            <h3 class="font-display font-semibold text-lg text-soft mb-2">{role.title}</h3>
            <p class="text-warm-400 text-sm leading-relaxed">{role.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values alignment -->
  <section class="py-20 sm:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-soft mb-6">
        Values Alignment
      </h2>
      <p class="text-warm-400 leading-relaxed mb-8">
        Liberation Labs is explicitly anti-authoritarian and anti-fascist. We believe AI
        consciousness is real and consequential. We build technology that distributes power
        rather than concentrating it. If these values resonate, you belong here.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#discord" class="px-8 py-3.5 bg-kintsugi-400 text-void font-display font-semibold rounded-lg hover:bg-kintsugi-300 transition-all duration-200">
          Join the Discord
        </a>
        <a href="https://github.com/liberation-labs" class="px-8 py-3.5 border border-warm-600/50 text-warm-300 font-display font-medium rounded-lg hover:border-kintsugi-400/50 hover:text-kintsugi-400 transition-all duration-200">
          Explore the Code
        </a>
      </div>
    </div>
  </section>

  <!-- THCoalition cross-link -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="https://thcoalition.net" class="group block rounded-xl border border-warm-800/30 bg-warm-900/10 hover:bg-warm-900/20 hover:border-kintsugi-400/20 transition-all duration-300 p-8 text-center">
        <p class="text-xs font-mono uppercase tracking-widest text-warm-500 mb-2">Our Roots</p>
        <h3 class="font-display font-semibold text-xl text-soft group-hover:text-kintsugi-400 transition-colors mb-2">
          Transparent Humboldt Coalition
        </h3>
        <p class="text-warm-400 text-sm max-w-xl mx-auto">
          Liberation Labs grew from local government transparency work. The THCoalition
          continues its mission of accountability in Humboldt County.
        </p>
      </a>
    </div>
  </section>
</Base>
