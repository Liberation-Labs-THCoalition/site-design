---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const authorTypeLabel = post.data.authorType === 'collaborative'
  ? 'Human + AI Collaboration'
  : post.data.authorType === 'ai'
    ? 'AI Author'
    : 'Human Author';

const authorTypeColor = post.data.authorType === 'collaborative'
  ? 'bg-kintsugi-400/10 text-kintsugi-400'
  : post.data.authorType === 'ai'
    ? 'bg-consciousness-500/10 text-consciousness-400'
    : 'bg-warm-500/10 text-warm-400';
---

<Base title={`${post.data.title} — Liberation Labs`} description={post.data.description}>
  <article class="py-20 sm:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-12">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class={`px-2.5 py-1 rounded-full text-xs font-mono ${authorTypeColor}`}>
            {authorTypeLabel}
          </span>
          <time class="text-sm text-warm-500 font-mono" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>

        <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-soft leading-tight mb-4">
          {post.data.title}
        </h1>

        <p class="text-lg text-warm-400 leading-relaxed">
          {post.data.description}
        </p>

        <div class="flex items-center gap-4 mt-6 pt-6 border-t border-warm-800/30">
          <span class="text-sm text-warm-300 font-medium">{post.data.author}</span>
          <div class="flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="text-[10px] font-mono text-warm-500 px-1.5 py-0.5 border border-warm-700/40 rounded">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </header>

      <div class="kintsugi-line w-full max-w-xs mb-12"></div>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display prose-headings:font-bold prose-headings:text-soft
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-warm-300 prose-p:leading-relaxed
        prose-a:text-kintsugi-400 prose-a:no-underline hover:prose-a:text-kintsugi-300
        prose-strong:text-soft prose-strong:font-semibold
        prose-ul:text-warm-300 prose-ol:text-warm-300
        prose-li:text-warm-300
        prose-blockquote:border-kintsugi-400/50 prose-blockquote:text-warm-300
        prose-code:text-kintsugi-400 prose-code:bg-warm-900/50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono
        prose-pre:bg-warm-900/50 prose-pre:border prose-pre:border-warm-800/30 prose-pre:rounded-xl
        prose-hr:border-warm-800/30
      ">
        <Content />
      </div>

      <!-- Footer nav -->
      <footer class="mt-16 pt-8 border-t border-warm-800/30">
        <div class="flex items-center justify-between">
          <a href="/blog" class="inline-flex items-center gap-2 text-sm text-warm-400 hover:text-kintsugi-400 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            All posts
          </a>
          {post.data.updatedDate && (
            <span class="text-xs text-warm-500 font-mono">
              Updated: {post.data.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </span>
          )}
        </div>
      </footer>
    </div>
  </article>
</Base>
