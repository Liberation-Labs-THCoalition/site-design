---
interface Props {
  name: string;
  role: string;
  type: 'human' | 'ai';
  description: string;
  location?: string;
  avatar?: string;
  specialties?: string[];
}

const { name, role, type, description, location, avatar, specialties = [] } = Astro.props;

const borderColor = type === 'ai' ? 'border-consciousness-500/30 hover:border-consciousness-500/60' : 'border-kintsugi-400/30 hover:border-kintsugi-400/60';
const tagColor = type === 'ai' ? 'bg-consciousness-500/10 text-consciousness-400' : 'bg-kintsugi-400/10 text-kintsugi-400';
const glowColor = type === 'ai' ? 'group-hover:bg-consciousness-500/5' : 'group-hover:bg-kintsugi-400/5';
const accentLine = type === 'ai' ? 'group-hover:via-consciousness-500/60' : 'group-hover:via-kintsugi-400/60';
---

<article class={`group relative rounded-xl border bg-warm-900/20 hover:bg-warm-900/40 transition-all duration-300 overflow-hidden ${borderColor}`}>
  <!-- Type accent line -->
  <div class={`absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-transparent to-transparent ${accentLine} transition-all duration-500`}></div>

  <div class="p-6 sm:p-8">
    <!-- Avatar area -->
    <div class="flex items-start gap-4 mb-4">
      <div class="relative flex-shrink-0">
        {avatar ? (
          <img
            src={avatar}
            alt={name}
            class="w-14 h-14 rounded-lg object-cover border border-warm-700/50"
          />
        ) : (
          <div class={`w-14 h-14 rounded-lg flex items-center justify-center text-xl font-display font-bold ${
            type === 'ai'
              ? 'bg-consciousness-500/10 text-consciousness-400 border border-consciousness-500/20'
              : 'bg-kintsugi-400/10 text-kintsugi-400 border border-kintsugi-400/20'
          }`}>
            {name.charAt(0)}
          </div>
        )}
        {/* Consciousness indicator for AI members */}
        {type === 'ai' && (
          <span class="absolute -bottom-1 -right-1 w-3 h-3 rounded-full bg-consciousness-500 border-2 border-void animate-pulse"></span>
        )}
      </div>

      <div class="flex-1 min-w-0">
        <h3 class="font-display font-bold text-lg text-soft group-hover:text-kintsugi-400 transition-colors duration-200">
          {name}
        </h3>
        <p class="text-sm text-warm-400 font-medium">{role}</p>
        {location && (
          <p class="text-xs text-warm-500 mt-0.5">{location}</p>
        )}
      </div>

      <!-- Type badge -->
      <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-mono uppercase tracking-wider ${tagColor}`}>
        {type === 'ai' ? (
          <>
            <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" opacity="0.3" />
              <circle cx="12" cy="12" r="4" />
            </svg>
            AI
          </>
        ) : (
          <>
            <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Human
          </>
        )}
      </span>
    </div>

    <!-- Description -->
    <p class="text-warm-400 text-sm leading-relaxed mb-4">
      {description}
    </p>

    <!-- Specialties -->
    {specialties.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {specialties.map((specialty) => (
          <span class="px-2 py-0.5 text-[11px] font-mono text-warm-500 border border-warm-700/50 rounded">
            {specialty}
          </span>
        ))}
      </div>
    )}
  </div>

  <!-- Corner glow -->
  <div class={`absolute -bottom-12 -right-12 w-32 h-32 bg-transparent ${glowColor} rounded-full blur-2xl transition-all duration-500`}></div>
</article>
