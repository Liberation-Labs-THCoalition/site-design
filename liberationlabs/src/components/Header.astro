---
const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Team', href: '/team' },
  { label: 'Projects', href: '/projects' },
  { label: 'Research', href: '/research' },
  { label: 'Blog', href: '/blog' },
  { label: 'Join', href: '/join' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="absolute inset-0 bg-void/80 backdrop-blur-md border-b border-warm-800/30"></div>

  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="relative w-8 h-8 lg:w-10 lg:h-10">
          <!-- Kintsugi bowl icon -->
          <svg viewBox="0 0 40 40" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="20" r="18" stroke="#374151" stroke-width="1.5" />
            <path
              d="M8 22 C12 14, 18 10, 20 20 S28 26, 32 18"
              stroke="#d4a843"
              stroke-width="1.5"
              stroke-linecap="round"
              class="group-hover:stroke-kintsugi-300 transition-colors duration-300"
            />
            <path
              d="M14 8 C16 16, 20 24, 18 32"
              stroke="#d4a843"
              stroke-width="1"
              stroke-linecap="round"
              opacity="0.6"
              class="group-hover:opacity-100 transition-opacity duration-300"
            />
          </svg>
        </div>
        <div class="flex flex-col">
          <span class="font-display font-bold text-lg lg:text-xl tracking-tight text-soft group-hover:text-kintsugi-400 transition-colors duration-300">
            Liberation Labs
          </span>
          <span class="hidden sm:block text-[10px] uppercase tracking-[0.2em] text-warm-500 font-medium">
            Building minds that matter
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'relative px-4 py-2 text-sm font-medium transition-colors duration-200 rounded-lg',
              currentPath.startsWith(item.href)
                ? 'text-kintsugi-400'
                : 'text-warm-400 hover:text-soft',
            ]}
          >
            {item.label}
            {currentPath.startsWith(item.href) && (
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-4 h-0.5 bg-kintsugi-400 rounded-full" />
            )}
          </a>
        ))}
        <a
          href="/join"
          class="ml-4 px-5 py-2 bg-kintsugi-400/10 text-kintsugi-400 border border-kintsugi-400/30 rounded-lg text-sm font-medium hover:bg-kintsugi-400/20 hover:border-kintsugi-400/50 transition-all duration-200"
        >
          Get Involved
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden relative w-10 h-10 flex items-center justify-center text-warm-400 hover:text-soft transition-colors"
        aria-label="Toggle menu"
      >
        <div class="space-y-1.5" id="hamburger-icon">
          <span class="block w-6 h-0.5 bg-current transition-transform duration-300 origin-center"></span>
          <span class="block w-4 h-0.5 bg-current transition-opacity duration-300 ml-auto"></span>
          <span class="block w-6 h-0.5 bg-current transition-transform duration-300 origin-center"></span>
        </div>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-16 bg-void/95 backdrop-blur-lg transform translate-x-full transition-transform duration-300 ease-in-out z-40"
  >
    <nav class="flex flex-col items-center justify-center h-full gap-6 pb-20">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-2xl font-display font-medium transition-colors duration-200',
            currentPath.startsWith(item.href)
              ? 'text-kintsugi-400'
              : 'text-warm-300 hover:text-soft',
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="kintsugi-line w-24 my-4"></div>
      <a
        href="/join"
        class="px-8 py-3 bg-kintsugi-400/10 text-kintsugi-400 border border-kintsugi-400/30 rounded-lg text-lg font-medium hover:bg-kintsugi-400/20 transition-all duration-200"
      >
        Get Involved
      </a>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-20"></div>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerLines = document.querySelectorAll('#hamburger-icon span');
  let isOpen = false;

  menuBtn?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      hamburgerLines[0]?.classList.add('rotate-45', 'translate-y-[4px]');
      hamburgerLines[1]?.classList.add('opacity-0');
      hamburgerLines[2]?.classList.add('-rotate-45', '-translate-y-[4px]');
    } else {
      mobileMenu?.classList.add('translate-x-full');
      mobileMenu?.classList.remove('translate-x-0');
      hamburgerLines[0]?.classList.remove('rotate-45', 'translate-y-[4px]');
      hamburgerLines[1]?.classList.remove('opacity-0');
      hamburgerLines[2]?.classList.remove('-rotate-45', '-translate-y-[4px]');
    }
  });

  // Header scroll behavior
  let lastScroll = 0;
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;
    if (currentScroll > 100) {
      header?.classList.add('shadow-lg', 'shadow-void/50');
    } else {
      header?.classList.remove('shadow-lg', 'shadow-void/50');
    }
    lastScroll = currentScroll;
  });
</script>
