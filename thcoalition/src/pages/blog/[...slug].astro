---
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.pubDate);

const formattedUpdated = post.data.updatedDate
  ? new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(post.data.updatedDate)
  : null;

const categoryLabels: Record<string, string> = {
  investigation: 'Investigation',
  news: 'News',
  'press-release': 'Press Release',
  analysis: 'Analysis',
  'data-release': 'Data Release',
  community: 'Community',
};

const categoryStyles: Record<string, string> = {
  investigation: 'bg-red-50 text-red-700',
  news: 'bg-transparency-50 text-transparency-700',
  'press-release': 'bg-purple-50 text-purple-700',
  analysis: 'bg-navy-50 text-navy-700',
  'data-release': 'bg-emerald-50 text-emerald-700',
  community: 'bg-amber-50 text-amber-700',
};
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.heroImage}
>
  <article>
    <!-- Article Header -->
    <header class="bg-navy-900 py-16 sm:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="mb-8" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-sm text-slate-400">
            <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-slate-300 truncate" aria-current="page">{post.data.title}</li>
          </ol>
        </nav>

        <!-- Category -->
        <span class:list={[
          'inline-flex items-center px-2.5 py-0.5 rounded-full text-2xs font-semibold uppercase tracking-wider mb-4',
          categoryStyles[post.data.category] || categoryStyles.news,
        ]}>
          {categoryLabels[post.data.category] || 'News'}
        </span>

        <!-- Title -->
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">
          {post.data.title}
        </h1>

        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400">
          <span class="font-medium text-slate-300">{post.data.author}</span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          {formattedUpdated && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>Updated {formattedUpdated}</span>
            </>
          )}
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag: string) => (
              <span class="inline-flex items-center px-2 py-0.5 rounded text-2xs font-medium bg-navy-800 text-slate-300 border border-navy-700">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Hero Image -->
    {post.data.heroImage && (
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6">
        <img
          src={post.data.heroImage}
          alt=""
          class="w-full rounded-xl shadow-lg"
        />
      </div>
    )}

    <!-- Article Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <div class="prose prose-lg prose-slate max-w-none">
        <Content />
      </div>

      <!-- Share / Back -->
      <div class="mt-16 pt-8 border-t border-slate-200 flex items-center justify-between">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-navy-900 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m12 19-7-7 7-7"/>
            <path d="M19 12H5"/>
          </svg>
          Back to all posts
        </a>
        <div class="flex items-center gap-3">
          <span class="text-sm text-slate-500">Share:</span>
          <a
            href={`https://bsky.app/intent/compose?text=${encodeURIComponent(post.data.title + ' ' + Astro.url)}`}
            class="text-slate-400 hover:text-transparency-600 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Share on BlueSky"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.625 3.504 6.27 3.198-4.073.581-7.677 2.411-4.406 7.47 3.486 4.904 6.632-1.376 7.512-3.376.88 2 2.168 8.085 7.512 3.376 3.372-5.22-.837-6.889-4.406-7.47 2.645.306 5.485-.571 6.27-3.198C19.622 9.418 20 4.458 20 3.768c0-.689-.139-1.861-.902-2.203-.659-.3-1.664-.621-4.3 1.24C12.046 4.747 9.087 8.686 12 10.8z"/>
            </svg>
          </a>
          <a
            href={`mailto:?subject=${encodeURIComponent(post.data.title)}&body=${encodeURIComponent('Read this from the Transparent Humboldt Coalition: ' + Astro.url)}`}
            class="text-slate-400 hover:text-transparency-600 transition-colors"
            aria-label="Share via email"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </article>
</Base>
