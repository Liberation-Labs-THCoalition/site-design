---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const focusAreas = [
  {
    icon: 'dollar',
    title: 'Financial Oversight',
    description: 'Tracking county budgets, expenditures, and contract awards. Every dollar accounted for, every transaction visible.',
  },
  {
    icon: 'document',
    title: 'Public Records',
    description: 'Filing FOIA requests and publishing results. Government records belong to the public — we make sure they stay there.',
  },
  {
    icon: 'eye',
    title: 'Meeting Monitoring',
    description: 'Attending and documenting Board of Supervisors meetings, planning commissions, and committee hearings.',
  },
  {
    icon: 'database',
    title: 'Data Infrastructure',
    description: 'Building open tools that make raw government data searchable, downloadable, and understandable.',
  },
];
---

<Base title="Home">
  <Hero />

  <!-- Focus Areas -->
  <section class="py-20 bg-white" aria-labelledby="focus-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 id="focus-heading" class="font-display text-3xl sm:text-4xl font-bold text-navy-900 mb-4">
          What We Watch
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Systematic, nonpartisan monitoring of Humboldt County government.
          We follow the data wherever it leads.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {focusAreas.map((area) => (
          <div class="relative p-6 rounded-xl border border-slate-200 hover:border-transparency-200 hover:shadow-md transition-all duration-200 group">
            <div class="w-12 h-12 rounded-lg bg-transparency-50 group-hover:bg-transparency-100 flex items-center justify-center mb-4 transition-colors duration-200">
              {area.icon === 'dollar' && (
                <svg class="w-6 h-6 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="12" y1="1" x2="12" y2="23"/>
                  <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
              )}
              {area.icon === 'document' && (
                <svg class="w-6 h-6 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
              )}
              {area.icon === 'eye' && (
                <svg class="w-6 h-6 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              )}
              {area.icon === 'database' && (
                <svg class="w-6 h-6 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <ellipse cx="12" cy="5" rx="9" ry="3"/>
                  <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/>
                  <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>
                </svg>
              )}
            </div>
            <h3 class="text-lg font-semibold text-navy-900 mb-2">{area.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{area.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest News -->
  <section class="py-20 bg-slate-50" aria-labelledby="news-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <h2 id="news-heading" class="font-display text-3xl sm:text-4xl font-bold text-navy-900 mb-2">
            Latest Updates
          </h2>
          <p class="text-lg text-slate-600">
            News, investigations, and data releases from the coalition.
          </p>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-transparency-600 hover:text-transparency-700 transition-colors">
          View all posts
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      {latestPosts.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {latestPosts.map((post) => (
            <NewsCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.slug}
              category={post.data.category}
              author={post.data.author}
              heroImage={post.data.heroImage}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-white rounded-xl border border-slate-200">
          <p class="text-slate-500">New posts coming soon. Check back or subscribe to our newsletter.</p>
        </div>
      )}

      <div class="mt-8 text-center sm:hidden">
        <a href="/blog" class="inline-flex items-center gap-1 text-sm font-semibold text-transparency-600 hover:text-transparency-700">
          View all posts &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Data Highlight -->
  <section class="py-20 bg-navy-900" aria-labelledby="data-highlight-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-amber-500/10 text-amber-400 text-xs font-semibold uppercase tracking-wider mb-6">
            Open Data
          </span>
          <h2 id="data-highlight-heading" class="font-display text-3xl sm:text-4xl font-bold text-white mb-6 leading-tight">
            Raw Data.<br/>No Spin.<br/>Your Right.
          </h2>
          <p class="text-lg text-slate-300 leading-relaxed mb-8">
            We publish source documents alongside every analysis. Download county budgets,
            contract records, meeting minutes, and FOIA responses. Verify our work.
            Draw your own conclusions.
          </p>
          <a
            href="/data"
            class="inline-flex items-center gap-2 px-6 py-3 bg-amber-500 hover:bg-amber-400 text-navy-900 font-semibold rounded-lg transition-colors duration-150"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Browse Public Data
          </a>
        </div>
        <div class="mt-12 lg:mt-0">
          <div class="bg-navy-800 rounded-xl p-6 border border-navy-700 font-mono text-sm">
            <div class="flex items-center gap-2 mb-4 pb-4 border-b border-navy-700">
              <span class="w-3 h-3 rounded-full bg-red-500/60" aria-hidden="true"></span>
              <span class="w-3 h-3 rounded-full bg-amber-500/60" aria-hidden="true"></span>
              <span class="w-3 h-3 rounded-full bg-emerald-500/60" aria-hidden="true"></span>
              <span class="ml-2 text-slate-500 text-xs">thcoalition.net/data</span>
            </div>
            <div class="space-y-2 text-slate-300">
              <p><span class="text-slate-500">$</span> ls data/humboldt-county/</p>
              <p class="text-transparency-400">budgets/</p>
              <p class="text-transparency-400">contracts/</p>
              <p class="text-transparency-400">foia-responses/</p>
              <p class="text-transparency-400">meeting-minutes/</p>
              <p class="text-transparency-400">salary-data/</p>
              <p class="text-transparency-400">vendor-payments/</p>
              <p class="mt-3"><span class="text-slate-500">$</span> wc -l contracts/fy2024/*.csv</p>
              <p class="text-amber-400">  3,847 total records</p>
              <p class="mt-3"><span class="text-slate-500">$</span> <span class="animate-pulse">_</span></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white" aria-labelledby="cta-heading">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cta-heading" class="font-display text-3xl sm:text-4xl font-bold text-navy-900 mb-4">
        Transparency Takes a Community
      </h2>
      <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto">
        Whether you can volunteer time, share expertise, or simply spread the word,
        there's a role for you in building a more transparent Humboldt County.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 bg-transparency-500 hover:bg-transparency-600 text-white font-semibold rounded-lg transition-colors duration-150"
        >
          Get Involved
        </a>
        <a
          href="/about"
          class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 hover:border-slate-400 text-slate-700 hover:text-navy-900 font-semibold rounded-lg transition-colors duration-150"
        >
          Learn About Our Mission
        </a>
      </div>
    </div>
  </section>
</Base>
