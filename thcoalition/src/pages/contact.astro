---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contact"
  description="Get in touch with the Transparent Humboldt Coalition. Report tips, volunteer, ask questions, or join our newsletter."
>
  <!-- Page Header -->
  <section class="bg-navy-900 py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-6">
          Get in Touch
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed">
          Have a tip? Want to volunteer? Questions about our work?
          We're here and we're listening.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-5 lg:gap-16">
        <!-- Contact Form -->
        <div class="lg:col-span-3 mb-12 lg:mb-0">
          <div class="bg-white rounded-xl border border-slate-200 p-6 sm:p-8">
            <h2 class="font-display text-2xl font-bold text-navy-900 mb-6">Send Us a Message</h2>
            <form action="#" method="POST" class="space-y-6">
              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Name
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-transparency-500 focus:border-transparent"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
                    Email
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-transparency-500 focus:border-transparent"
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Subject
                </label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-transparency-500 focus:border-transparent"
                >
                  <option value="">Select a topic...</option>
                  <option value="tip">Submit a Tip</option>
                  <option value="volunteer">I Want to Volunteer</option>
                  <option value="data">Data Request or Question</option>
                  <option value="media">Media Inquiry</option>
                  <option value="partnership">Partnership Opportunity</option>
                  <option value="general">General Question</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="6"
                  required
                  class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-transparency-500 focus:border-transparent resize-y"
                  placeholder="Tell us what's on your mind..."
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input
                  type="checkbox"
                  id="anonymous"
                  name="anonymous"
                  class="mt-1 rounded border-slate-300 text-transparency-500 focus:ring-transparency-500"
                />
                <label for="anonymous" class="text-sm text-slate-600">
                  I'd like to remain anonymous. Don't associate my name with this message.
                </label>
              </div>

              <button
                type="submit"
                class="w-full sm:w-auto px-6 py-3 bg-transparency-500 hover:bg-transparency-600 text-white font-semibold rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-transparency-500 focus:ring-offset-2"
              >
                Send Message
              </button>
            </form>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Secure Tips -->
          <div class="bg-amber-50 rounded-xl border border-amber-200 p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </div>
              <h3 class="font-semibold text-navy-900">Secure Tips</h3>
            </div>
            <p class="text-sm text-slate-700 leading-relaxed mb-3">
              Have information about government misconduct? We protect
              our sources. For maximum security, contact us via:
            </p>
            <ul class="space-y-2 text-sm text-slate-700">
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-amber-500 flex-shrink-0" aria-hidden="true"></span>
                Encrypted email (PGP key available on request)
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-amber-500 flex-shrink-0" aria-hidden="true"></span>
                Signal: available upon verified request
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1 h-1 rounded-full bg-amber-500 flex-shrink-0" aria-hidden="true"></span>
                Physical mail (no return address needed)
              </li>
            </ul>
          </div>

          <!-- Direct Contact -->
          <div class="bg-white rounded-xl border border-slate-200 p-6">
            <h3 class="font-semibold text-navy-900 mb-4">Direct Contact</h3>
            <dl class="space-y-4">
              <div>
                <dt class="text-2xs font-medium text-slate-500 uppercase tracking-wider mb-1">Email</dt>
                <dd>
                  <a href="mailto:info@thcoalition.net" class="text-sm text-transparency-600 hover:text-transparency-700 font-medium">
                    info@thcoalition.net
                  </a>
                </dd>
              </div>
              <div>
                <dt class="text-2xs font-medium text-slate-500 uppercase tracking-wider mb-1">Location</dt>
                <dd class="text-sm text-slate-700">
                  Humboldt County, California<br/>
                  Eureka area
                </dd>
              </div>
              <div>
                <dt class="text-2xs font-medium text-slate-500 uppercase tracking-wider mb-1">Social</dt>
                <dd class="flex items-center gap-3 mt-1">
                  <a href="#" class="text-slate-400 hover:text-transparency-600 transition-colors" aria-label="Mastodon">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M23.268 5.313c-.35-2.578-2.617-4.61-5.304-5.004C17.51.242 15.792 0 11.813 0h-.03c-3.98 0-4.835.242-5.288.309C3.882.692 1.496 2.518.917 5.127.64 6.412.61 7.837.661 9.143c.074 1.874.088 3.745.26 5.611.118 1.24.325 2.47.62 3.68.55 2.237 2.777 4.098 4.96 4.857 2.336.792 4.849.923 7.256.38.265-.061.527-.132.786-.213.585-.184 1.27-.39 1.774-.753a.057.057 0 0 0 .023-.043v-1.809a.052.052 0 0 0-.02-.041.053.053 0 0 0-.046-.01 20.282 20.282 0 0 1-4.709.545c-2.73 0-3.463-1.284-3.674-1.818a5.593 5.593 0 0 1-.319-1.433.053.053 0 0 1 .066-.054 19.648 19.648 0 0 0 4.636.546c.568 0 1.133-.014 1.691-.049 2.938-.187 5.795-.825 5.932-5.462.006-.216.049-2.241.049-2.462 0-.753.219-5.336-.351-7.864z"/>
                    </svg>
                  </a>
                  <a href="#" class="text-slate-400 hover:text-transparency-600 transition-colors" aria-label="BlueSky">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.785 2.627 3.625 3.504 6.27 3.198-4.073.581-7.677 2.411-4.406 7.47 3.486 4.904 6.632-1.376 7.512-3.376.88 2 2.168 8.085 7.512 3.376 3.372-5.22-.837-6.889-4.406-7.47 2.645.306 5.485-.571 6.27-3.198C19.622 9.418 20 4.458 20 3.768c0-.689-.139-1.861-.902-2.203-.659-.3-1.664-.621-4.3 1.24C12.046 4.747 9.087 8.686 12 10.8z"/>
                    </svg>
                  </a>
                </dd>
              </div>
            </dl>
          </div>

          <!-- Newsletter -->
          <div class="bg-navy-900 rounded-xl p-6">
            <h3 class="font-semibold text-white mb-3">Newsletter</h3>
            <p class="text-sm text-slate-300 mb-4">
              Investigation alerts, data releases, and community updates.
              Monthly at most.
            </p>
            <form action="#" method="POST" class="space-y-3">
              <label for="sidebar-email" class="sr-only">Email address</label>
              <input
                id="sidebar-email"
                type="email"
                name="email"
                placeholder="you@example.com"
                required
                class="w-full px-3 py-2 bg-navy-800 border border-navy-700 rounded-md text-sm text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-transparency-500 focus:border-transparent"
              />
              <button
                type="submit"
                class="w-full px-4 py-2 bg-transparency-500 hover:bg-transparency-600 text-white text-sm font-medium rounded-md transition-colors duration-150"
              >
                Subscribe
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
