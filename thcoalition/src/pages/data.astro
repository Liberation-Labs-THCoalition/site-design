---
import Base from '../layouts/Base.astro';

const datasets = [
  {
    id: 'budgets',
    title: 'County Budgets',
    description: 'Annual adopted budgets and mid-year adjustments for Humboldt County, broken down by department and fund.',
    format: 'CSV / PDF',
    years: '2019-2024',
    size: '12.4 MB',
    lastUpdated: 'January 2024',
    icon: 'dollar',
  },
  {
    id: 'contracts',
    title: 'Contract Awards',
    description: 'All county contracts over $10,000, including vendor, amount, duration, competitive bid status, and awarding department.',
    format: 'CSV / JSON',
    years: '2020-2024',
    size: '8.7 MB',
    lastUpdated: 'March 2024',
    icon: 'document',
  },
  {
    id: 'meetings',
    title: 'Meeting Minutes & Agendas',
    description: 'Board of Supervisors, Planning Commission, and committee meeting agendas with linked documents and vote records.',
    format: 'PDF / CSV index',
    years: '2022-2024',
    size: '45.2 MB',
    lastUpdated: 'March 2024',
    icon: 'calendar',
  },
  {
    id: 'foia',
    title: 'FOIA Responses',
    description: 'Complete public records request responses with original documents, correspondence, and request tracking data.',
    format: 'PDF / various',
    years: '2022-2024',
    size: '128 MB',
    lastUpdated: 'February 2024',
    icon: 'folder',
  },
  {
    id: 'salaries',
    title: 'Public Employee Compensation',
    description: 'Salary and total compensation data for Humboldt County employees, sourced from California State Controller reports.',
    format: 'CSV',
    years: '2019-2023',
    size: '3.1 MB',
    lastUpdated: 'December 2023',
    icon: 'users',
  },
  {
    id: 'vendors',
    title: 'Vendor Payment Records',
    description: 'Individual payment transactions to county vendors, including check register data and purchase order details.',
    format: 'CSV',
    years: '2021-2024',
    size: '22.8 MB',
    lastUpdated: 'March 2024',
    icon: 'receipt',
  },
];
---

<Base
  title="Public Data"
  description="Download raw government data from Humboldt County: budgets, contracts, meeting minutes, FOIA responses, salary data, and more."
>
  <!-- Page Header -->
  <section class="bg-navy-900 py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-amber-500/10 text-amber-400 text-xs font-semibold uppercase tracking-wider mb-6">
          Open Data
        </span>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-white mb-6">
          Public Data Portal
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed">
          Raw government data. No paywall. No registration. Download county records,
          FOIA responses, and financial documents. Verify our work. Do your own analysis.
        </p>
      </div>
    </div>
  </section>

  <!-- Principles Bar -->
  <section class="bg-white border-b border-slate-200 py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-slate-600">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>No registration required</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Machine-readable formats</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>CC BY 4.0 license</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Updated regularly</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Datasets -->
  <section class="py-16 sm:py-20 bg-slate-50" aria-labelledby="datasets-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="datasets-heading" class="sr-only">Available Datasets</h2>
      <div class="grid gap-6">
        {datasets.map((dataset) => (
          <div id={dataset.id} class="bg-white rounded-xl border border-slate-200 hover:border-transparency-200 hover:shadow-md transition-all duration-200 p-6 sm:p-8 scroll-mt-24">
            <div class="sm:flex sm:items-start sm:justify-between gap-6">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-transparency-50 flex items-center justify-center flex-shrink-0">
                    {dataset.icon === 'dollar' && (
                      <svg class="w-5 h-5 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                      </svg>
                    )}
                    {dataset.icon === 'document' && (
                      <svg class="w-5 h-5 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                      </svg>
                    )}
                    {dataset.icon === 'calendar' && (
                      <svg class="w-5 h-5 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                      </svg>
                    )}
                    {dataset.icon === 'folder' && (
                      <svg class="w-5 h-5 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                      </svg>
                    )}
                    {dataset.icon === 'users' && (
                      <svg class="w-5 h-5 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                      </svg>
                    )}
                    {dataset.icon === 'receipt' && (
                      <svg class="w-5 h-5 text-transparency-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                      </svg>
                    )}
                  </div>
                  <h3 class="text-xl font-semibold text-navy-900 font-display">{dataset.title}</h3>
                </div>
                <p class="text-slate-600 leading-relaxed mb-4">{dataset.description}</p>
                <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-500">
                  <span><strong class="text-slate-700">Format:</strong> {dataset.format}</span>
                  <span><strong class="text-slate-700">Coverage:</strong> {dataset.years}</span>
                  <span><strong class="text-slate-700">Size:</strong> {dataset.size}</span>
                  <span><strong class="text-slate-700">Updated:</strong> {dataset.lastUpdated}</span>
                </div>
              </div>
              <div class="mt-4 sm:mt-0 flex-shrink-0">
                <button
                  class="inline-flex items-center gap-2 px-5 py-2.5 bg-navy-900 hover:bg-navy-800 text-white text-sm font-medium rounded-lg transition-colors duration-150"
                  aria-label={`Download ${dataset.title}`}
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                  </svg>
                  Download
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FOIA Guide -->
  <section class="py-16 sm:py-20 bg-white" aria-labelledby="foia-guide-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-start">
        <div>
          <h2 id="foia-guide-heading" class="font-display text-3xl font-bold text-navy-900 mb-4">
            File Your Own Records Request
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-6">
            California's Public Records Act gives every person the right to inspect
            and copy public records. You don't need a lawyer. You don't need a reason.
            Here's how to do it.
          </p>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-transparency-600 hover:text-transparency-700 font-semibold transition-colors"
          >
            Read our full FOIA guide
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class="mt-8 lg:mt-0">
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-transparency-100 text-transparency-700 flex items-center justify-center text-sm font-bold">1</span>
              <div>
                <h3 class="font-semibold text-navy-900">Identify the records you want</h3>
                <p class="text-sm text-slate-600 mt-1">Be specific. "All emails between X and Y regarding Z from January to March 2024" works better than "everything about Z."</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-transparency-100 text-transparency-700 flex items-center justify-center text-sm font-bold">2</span>
              <div>
                <h3 class="font-semibold text-navy-900">Submit your request in writing</h3>
                <p class="text-sm text-slate-600 mt-1">Email, mail, or hand-deliver to the relevant department. No form required, but written requests create a paper trail.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-transparency-100 text-transparency-700 flex items-center justify-center text-sm font-bold">3</span>
              <div>
                <h3 class="font-semibold text-navy-900">Wait for the response</h3>
                <p class="text-sm text-slate-600 mt-1">Agencies must respond within 10 days (can extend by 14 days in some cases). If they don't respond, follow up.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-transparency-100 text-transparency-700 flex items-center justify-center text-sm font-bold">4</span>
              <div>
                <h3 class="font-semibold text-navy-900">Know your rights if denied</h3>
                <p class="text-sm text-slate-600 mt-1">Agencies must cite specific legal exemptions for any denied records. Generic denials are not permitted under California law.</p>
              </div>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- API Notice -->
  <section class="py-12 bg-slate-50 border-t border-slate-200">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-slate-600">
        <strong class="text-navy-900">Need programmatic access?</strong>
        We're building a public API for automated data retrieval.
        <a href="/contact" class="text-transparency-600 hover:text-transparency-700 font-medium">Contact us</a>
        if you're interested in early access.
      </p>
    </div>
  </section>
</Base>
