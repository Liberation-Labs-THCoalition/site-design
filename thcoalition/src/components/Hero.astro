---
interface Props {
  title?: string;
  subtitle?: string;
  showStats?: boolean;
}

const {
  title = 'Shining Light on\nHumboldt County Government',
  subtitle = 'We monitor public finances, track government contracts, attend committee meetings, and publish raw data so every resident can hold power accountable.',
  showStats = true,
} = Astro.props;

const stats = [
  { value: '200+', label: 'FOIA Requests Filed' },
  { value: '50+', label: 'Meetings Monitored' },
  { value: '$2.4M', label: 'In Contracts Tracked' },
  { value: '2022', label: 'Year Founded' },
];
---

<section class="relative bg-navy-900 overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)"/>
    </svg>
  </div>

  <!-- Gradient Accent -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-transparency-500/10 to-transparent" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-amber-500/5 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-transparency-500/10 border border-transparency-500/20 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-transparency-400 animate-pulse" aria-hidden="true"></span>
        <span class="text-xs font-medium text-transparency-300 uppercase tracking-wider">Government Watchdog Since 2022</span>
      </div>

      <!-- Headline -->
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.1] mb-6 whitespace-pre-line">
        {title}
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-slate-300 leading-relaxed max-w-2xl mb-10">
        {subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/investigations"
          class="inline-flex items-center justify-center px-6 py-3 bg-transparency-500 hover:bg-transparency-600 text-white font-semibold rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-transparency-400 focus:ring-offset-2 focus:ring-offset-navy-900"
        >
          View Investigations
          <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a
          href="/data"
          class="inline-flex items-center justify-center px-6 py-3 border border-slate-600 hover:border-slate-400 text-slate-200 hover:text-white font-semibold rounded-lg transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 focus:ring-offset-navy-900"
        >
          Browse Public Data
        </a>
      </div>
    </div>

    <!-- Stats Bar -->
    {showStats && (
      <div class="mt-16 pt-10 border-t border-white/10">
        <dl class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center sm:text-left">
              <dt class="text-2xs font-medium text-slate-400 uppercase tracking-wider mb-1">{stat.label}</dt>
              <dd class="text-2xl sm:text-3xl font-bold text-white font-display">{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}
  </div>
</section>
